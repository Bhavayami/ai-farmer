# Gemini API Credentials
GEMINI_API_KEY=your_gemini_api_key_here

# App Configurations
LOG_LEVEL=INFO
APP_PORT=8501
SECRET_KEY=generate_a_random_32_bytes_key_here_for_encryption

# Database URLs
SQL_DATABASE_URL=sqlite:///farming.db

# External API Keys (Mocks will be used if keys are missing)
MAPS_API_KEY=your_google_maps_api_key_here
WEATHER_API_KEY=your_weather_api_key_here
MARKET_API_KEY=your_market_api_key_here
